# FHIR server — use service name when running in Docker, localhost for local dev
FHIR_BASE_URL=http://fhir:8080/fhir

# Leave blank to skip auth (HAPI is open when accessed directly inside Docker)
# Set when going through OpenResty: admin / password
FHIR_USERNAME=
FHIR_PASSWORD=

# How long (seconds) to cache patient-ID lists and SNOMED counts from FHIR
COUNT_CACHE_TTL=300

# App metadata
APP_TITLE=FHIR Package Catalogue API
APP_VERSION=1.0.0
